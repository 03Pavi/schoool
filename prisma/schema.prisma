generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

model Grade {
  id          String         @id @default(cuid())
  name        String         @unique
  status      RecordStatus   @default(ACTIVE)
  classLinks  GradeClass[]
  subjectLinks GradeSubject[]
  teacherAssignments TeacherAcademicAssignment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model SchoolClass {
  id             String               @id @default(cuid())
  name           String
  status         RecordStatus         @default(ACTIVE)
  gradeLinks     GradeClass[]
  sectionLinks   ClassSection[]
  subjectLinks   ClassSubject[]
  enrollments    StudentClassEnrollment[]
  teacherAssignments TeacherAcademicAssignment[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([name])
}

model Section {
  id         String         @id @default(cuid())
  name       String
  status     RecordStatus   @default(ACTIVE)
  classLinks ClassSection[]
  teacherAssignments TeacherAcademicAssignment[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([name])
}

model Subject {
  id             String                      @id @default(cuid())
  name           String
  code           String                      @unique
  status         RecordStatus                @default(ACTIVE)
  gradeLinks     GradeSubject[]
  classLinks     ClassSubject[]
  studentLinks   StudentSubjectEnrollment[]
  teacherAssignments TeacherAcademicAssignment[]
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@unique([name])
}

model StudentProfile {
  id           String                      @id @default(cuid())
  fullName     String
  email        String?                     @unique
  status       RecordStatus                @default(ACTIVE)
  classLinks   StudentClassEnrollment[]
  subjectLinks StudentSubjectEnrollment[]
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
}

model TeacherProfile {
  id           String                      @id @default(cuid())
  fullName     String
  email        String?                     @unique
  status       RecordStatus                @default(ACTIVE)
  assignments  TeacherAcademicAssignment[]
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
}

model GradeClass {
  gradeId     String
  classId     String
  createdAt   DateTime @default(now())
  grade       Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  schoolClass SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([gradeId, classId])
}

model ClassSection {
  classId    String
  sectionId  String
  createdAt  DateTime @default(now())
  schoolClass SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  section    Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@id([classId, sectionId])
}

model GradeSubject {
  gradeId    String
  subjectId  String
  createdAt  DateTime @default(now())
  grade      Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([gradeId, subjectId])
}

model ClassSubject {
  classId    String
  subjectId  String
  createdAt  DateTime @default(now())
  schoolClass SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([classId, subjectId])
}

model StudentClassEnrollment {
  studentId  String
  classId    String
  createdAt  DateTime @default(now())
  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolClass SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([studentId, classId])
}

model StudentSubjectEnrollment {
  studentId  String
  subjectId  String
  createdAt  DateTime @default(now())
  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([studentId, subjectId])
}

model TeacherAcademicAssignment {
  id         String   @id @default(cuid())
  teacherId  String
  gradeId    String?
  classId    String?
  sectionId  String?
  subjectId  String?
  createdAt  DateTime @default(now())
  teacher    TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  grade      Grade?    @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  schoolClass SchoolClass? @relation(fields: [classId], references: [id], onDelete: SetNull)
  section    Section?  @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  subject    Subject?  @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@unique([teacherId, gradeId, classId, sectionId, subjectId])
}
